# Copy to .env and fill in. NEVER commit real keys.

# --- TTS backend ---
# supertonic (default) runs entirely on your own machine — no API key, no bills.
# Start it alongside `bun start`:
#   uv run --with 'supertonic[serve]' supertonic serve --port 7788 --log-level warning &
# TTS_BACKEND=supertonic                 # default: local, private, free
# SUPERTONIC_URL=http://127.0.0.1:7788
# SUPERTONIC_VOICE=M5
# SUPERTONIC_STEPS=5                     # diffusion steps; more = better/slower

# Kokoro-82M runs on your own GPU — local, private, free, and ~25x faster than
# realtime (RTF ~0.04, ~200ms per reply on a 7900 XT). Start the sidecar first;
# the exact command depends on your GPU vendor — see README "Local GPU TTS":
#   cd kokoro_test && uv run kokoro_sidecar.py &   # NVIDIA/CPU (AMD/ROCm: see README)
# TTS_BACKEND=kokoro
# KOKORO_URL=http://127.0.0.1:7100
# KOKORO_VOICE=am_onyx,am_michael          # blend: depth + clarity (comma averages style vectors)
# KOKORO_SPEED=0.9                        # <1 = slower/graver (DM gravitas); 1.0 = normal
# KOKORO_DEVICE=cuda                      # sidecar-side; auto-detects, set cpu to force fallback

# Cartesia is a premium fallback — higher quality and lower latency than the
# local model, at the cost of an API key and per-character billing. Uncomment to
# switch over:
# TTS_BACKEND=cartesia
# CARTESIA_API_KEY=sk_car_your_key_here
# CARTESIA_VOICE_ID=79f8b5fb-2cc8-479a-80df-29f7a7cf1a3e   # Theo - Modern Narrator
# CARTESIA_MODEL=sonic-3.5
# CARTESIA_VERSION=2026-03-01

# --- LLM (Gemma, multimodal, on your own GPU) ---
# LLAMA_URL=http://0.0.0.0:8001
# LLAMA_MODEL=zork-best                  # model name/alias your llama-server exposes
# LLAMA_API_KEY=                         # sent as Authorization: Bearer if set
# PORT=3000

# --- debugging ---
# DEBUG_TRANSCRIPT=1                     # Gemma prefixes [heard: ...] with its transcript guess
# DEBUG_AUDIO=1                          # dump each utterance WAV to debug/ (or set a dir)
